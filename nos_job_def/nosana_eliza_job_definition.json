{
  "ops": [
    {
      "id": "aeterna",
      "args": {
        "image": "theideabased/aeterna:latest",
        "expose": 3000,
        "env": {
          "GEMINI_API_KEY": "",
          "PIXABAY_API_KEY": "",
          "NODE_ENV": "production",
          "PYTHONUNBUFFERED": "1"
        },
        "resources": {
          "gpu": true
        }
      },
      "execution": {
        "group": "run"
      },
      "type": "container/run"
    }
  ],
  "version": "0.1"
}
