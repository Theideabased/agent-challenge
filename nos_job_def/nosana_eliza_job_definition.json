{
  "version": "0.1",
  "type": "container",
  "meta": {
    "trigger": "dashboard",
    "system_requirements": {
      "required_vram": 4
    }
  },
  "ops": [
    {
      "id": "elizareels",
      "type": "container/run",
      "args": {
        "image": "docker.io/seyman101/aeterna:latest",
        "gpu": true,
        "expose": 3000,
        "env": {
          "GEMINI_API_KEY": "",
          "PIXABAY_API_KEY": "",
          "NODE_ENV": "production",
          "PYTHONUNBUFFERED": "1"
        }
      }
    }
  ]
}
