# This file specifies files that are *not* uploaded to Google Cloud
# using gcloud. It follows the same syntax as .gitignore.

.gcloudignore
.git
.gitignore
__pycache__/
*.pyc

# Virtual environments (MUST exclude)
.venv/
.venv
venv/
venv
env/
env

# Storage and cache (will be created at runtime)
storage/
storage
*.mp4
*.avi
*.mov

# Keep fonts and songs for video creation
# resource/fonts and resource/songs are needed

# Logs
*.log
logs/

# Development files
.env
.env.local
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Documentation
*.md
!README.md

# Test files
test/

# Build artifacts
*.so
build/
dist/
*.egg-info/

# Deployment files
deployment.log
Dockerfile.streamlit
